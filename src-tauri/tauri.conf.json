{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nemefisto",
  "version": "0.1.0",
  "identifier": "com.nemefisto.vpn-client",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Nemefisto",
        "width": 460,
        "height": 920,
        "minWidth": 420,
        "minHeight": 760
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["nemefisto"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "category": "Network",
    "publisher": "Nemefisto",
    "shortDescription": "VPN-клиент на Xray-core и Mihomo",
    "longDescription": "Лёгкий VPN-клиент для Windows на базе Xray-core и Mihomo. Поддержка VLESS, VMess, Trojan, Shadowsocks, Hysteria2, TUIC, WireGuard, AnyTLS. Подключение в один клик через системный прокси или TUN.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/xray",
      "binaries/tun2socks",
      "binaries/mihomo"
    ],
    "resources": {
      "binaries/wintun.dll": "wintun.dll",
      "binaries/nemefisto-helper-x86_64-pc-windows-msvc.exe": "nemefisto-helper-x86_64-pc-windows-msvc.exe",
      "binaries/geoip.dat": "resources/geoip.dat",
      "binaries/geosite.dat": "resources/geosite.dat"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "installMode": "currentUser",
        "languages": ["English", "Russian"],
        "displayLanguageSelector": false
      }
    }
  }
}
